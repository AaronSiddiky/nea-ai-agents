# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Claude - used for outreach generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Harmonic.ai API (company intelligence)
# Get your key from: https://console.harmonic.ai/docs/dashboard
HARMONIC_API_KEY=your_harmonic_api_key

# Tavily API (website intelligence - FREE tier: 1,000 credits/month)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key

# The Swarm API (founder profile intelligence) — DISABLED
# Swarm integration has been removed. Founder backgrounds now enriched via Harmonic API.
# SWARM_API_KEY=your_swarm_api_key

# Parallel Search API (news research)
# Get your key from: https://parallel.ai/
PARALLEL_API_KEY=your_parallel_api_key

# LangSmith Tracing (optional - disabled by default)
# Uncomment and set these only if you need LangSmith observability.
# If you see 403 errors in logs, either rotate the key or leave these unset.
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_TRACING=false
# LANGSMITH_PROJECT=meeting-briefing-mvp

# Legacy LangChain tracing vars (deprecated - not recommended)
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=nea-ai-agents

# Supabase (for app-facing reads / writes)
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS allowlist — comma-separated origins allowed to call this API.
# Production must set this explicitly; defaults to localhost for dev.
ALLOWED_ORIGINS=http://localhost:3000

# Shared secret between NEA Scout (Node) and this Python service for
# server-to-server calls (canonical_bridge.py → Node, GitHub Actions cron
# → /api/internal/*). Generate 32+ random chars. The same value must be
# set on both the `neascout` Node service and this `nea-agents` service.
NEA_INTERNAL_SECRET=generate-a-random-32+char-string

# NEA Scout backend URL — used by canonical_bridge.py to resolve
# canonical_entity_id for every new entity written from this service.
NEA_BACKEND_URL=https://app.neascout.com

# Upstash Redis (for rate limiting)
# Get these from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# AUTH (post-M5: Supabase JWT is the only accepted scheme)
# =============================================================================

# Supabase HS256 JWT signing secret. Required when USE_SUPABASE_AUTH=true.
# Found in Supabase dashboard → Settings → API → JWT Settings → JWT secret.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Master switch for the write-endpoint auth middleware. Must be `true` in
# production. When `false`, every POST/DELETE/PUT/PATCH on /api/* (except
# /api/internal/*) returns 503 — we hard-fail rather than silently open
# the write surface.
USE_SUPABASE_AUTH=true

# =============================================================================
# OPTIONAL FEATURE FLAGS
# =============================================================================

# Structured LLM output (Phase 3.4)
# When true, uses Claude's with_structured_output() instead of regex parsing
# for briefing sections. More reliable but slightly higher latency.
USE_STRUCTURED_BRIEFING=false
